  "grammarRules": [
    {
      "title": "Basic Sentence Structure (SVO)",
      "explanation": "Chinese follows Subject-Verb-Object (SVO) structure, same as English. The subject comes first, followed by the verb, then the object.",
      "example": "我喝茶",
      "exampleTranslation": "I drink tea",
      "lessonLevel": 1
    },
    {
      "title": "Question Particle 吗 (ma)",
      "explanation": "Add 吗 (ma) at the end of a statement to turn it into a yes/no question. No change in word order is needed.",
      "example": "你好吗？",
      "exampleTranslation": "Are you good? / How are you?",
      "lessonLevel": 1
    },
    {
      "title": "Measure Words",
      "explanation": "Chinese uses measure words (classifiers) between numbers and nouns. Different nouns use different measure words. The most common is 个 (ge) for people and general objects.",
      "example": "三个人",
      "exampleTranslation": "Three people (three + MW + people)",
      "lessonLevel": 2
    },
    {
      "title": "的 (de) - Possessive Particle",
      "explanation": "的 (de) is placed between a noun/pronoun and another noun to indicate possession, similar to 's or 'of' in English. Pattern: Owner + 的 + Thing.",
      "example": "我的书",
      "exampleTranslation": "My book (I + possessive + book)",
      "lessonLevel": 2
    },
    {
      "title": "了 (le) - Completed Action",
      "explanation": "了 (le) is placed after a verb to indicate that an action has been completed or a state has changed. It marks the perfective aspect.",
      "example": "我吃了",
      "exampleTranslation": "I ate (I + eat + completed action)",
      "lessonLevel": 3
    }
  ],
