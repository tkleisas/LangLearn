  "grammarRules": [
    {
      "title": "Gender of Nouns",
      "explanation": "Spanish nouns have gender - masculine (usually ending in -o) and feminine (usually ending in -a). Articles change: el (masculine), la (feminine). Example: el libro (the book), la casa (the house).",
      "example": "el libro (the book), la casa (the house)",
      "exampleTranslation": "the book (m), the house (f)",
      "lessonLevel": 1
    },
    {
      "title": "Present Tense -AR Verbs",
      "explanation": "Regular -AR verbs conjugation: yo -o, tú -as, él/ella -a, nosotros -amos, ellos -an. Example: hablar (to speak) -> yo hablo, tú hablas, él habla, nosotros hablamos, ellos hablan.",
      "example": "hablar: yo hablo, tú hablas, él habla, nosotros hablamos, ellos hablan",
      "exampleTranslation": "I speak, you speak, he speaks, we speak, they speak",
      "lessonLevel": 2
    },
    {
      "title": "Ser vs Estar",
      "explanation": "Both mean \"to be\" but ser is for permanent traits, estar for temporary states/locations. Example: Yo soy profesor (I am a teacher - permanent). Yo estoy cansado (I am tired - temporary).",
      "example": "Yo soy profesor. Yo estoy cansado.",
      "exampleTranslation": "I am a teacher (ser) vs I am tired (estar)",
      "lessonLevel": 2
    },
    {
      "title": "Present Tense -ER/-IR Verbs",
      "explanation": "Regular -ER verbs: yo -o, tú -es, él -e, nosotros -emos, ellos -en. -IR verbs follow similar pattern. Example: comer (to eat) -> yo como, tú comes, él come.",
      "example": "comer: yo como, tú comes, él come, nosotros comemos, ellos comen",
      "exampleTranslation": "I eat, you eat, he eats, we eat, they eat",
      "lessonLevel": 3
    },
    {
      "title": "Direct Object Pronouns",
      "explanation": "lo, la, los, las replace direct objects. They go before the conjugated verb. Example: Veo el libro -> Lo veo (I see the book -> I see it).",
      "example": "Veo el libro -> Lo veo",
      "exampleTranslation": "I see the book -> I see it",
      "lessonLevel": 3
    }
  ],
